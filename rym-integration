//#region Constants

/** CORS proxy URL - using your personal Vercel proxy */
const CORS_PROXY = 'https://spicetify-rym.vercel.app/api/proxy?url=';

/** Cache duration in milliseconds (24 hours) */
const CACHE_DURATION = 24 * 60 * 60 * 1000;

/** Minimum similarity score for search match (0.0 - 1.0) */
const MIN_MATCH_SCORE = 0.6;

/** Artist name weight in similarity calculation */
const ARTIST_WEIGHT = 0.4;

/** Album name weight in similarity calculation */
const ALBUM_WEIGHT = 0.6;

/** Maximum number of genres to display */
const MAX_GENRES = 5;

/** Maximum number of descriptors to display */
const MAX_DESCRIPTORS = 8;

/** Maximum number of descriptors to parse */
const MAX_DESCRIPTORS_PARSE = 10;

// CSS Selectors
/** Selector for album page average rating */
const SELECTOR_AVG_RATING = '.avg_rating';

/** Selector for number of ratings */
const SELECTOR_NUM_RATINGS = '.num_ratings';

/** Selector for info header cells */
const SELECTOR_INFO_HDR = 'th.info_hdr';

/** Selector for primary genres */
const SELECTOR_PRIMARY_GENRES = '.release_pri_genres a.genre';

/** Selector for primary descriptors */
const SELECTOR_PRIMARY_DESCRIPTORS = '.release_pri_descriptors';

/** Selector for search result containers */
const SELECTOR_SEARCH_RESULTS = '.infobox';

/** Selector for search result links */
const SELECTOR_SEARCH_LINK = 'a.searchpage';

/** Selector for Spotify link button on RYM album pages */
const SELECTOR_SPOTIFY_LINK = 'a.ui_media_link_btn_spotify';

/** Selector for right sidebar content area (where About the artist, Credits, Next in queue are) */
const SELECTOR_RIGHT_SIDEBAR_CONTENT = '.main-nowPlayingView-nowPlayingGrid';

/** Alternative selector for right sidebar */
const SELECTOR_RIGHT_SIDEBAR_ALT = '[data-testid="NPV_Panel_OpenDiv"]';

/** RYM base URL */
const RYM_BASE_URL = 'https://rateyourmusic.com';

/** Container element ID */
const CONTAINER_ID = 'rym-container';

//#endregion

//#region State

/** @type {Map<string, CachedData>} */
const albumCache = new Map();

/** @type {string|null} Currently displayed album URI */
let currentAlbumUri = null;

//#endregion

//#region Cache Management

/**
 * Retrieves cached album data if valid
 * @param {string} albumUri - Spotify album URI
 * @returns {RYMAlbumData|null} Cached data or null if not found/expired
 */
function getCachedData(albumUri) {
  const cached = albumCache.get(albumUri);
  if (!cached) {
    return null;
  }

  if (Date.now() - cached.timestamp > CACHE_DURATION) {
    albumCache.delete(albumUri);
    return null;
  }

  return cached.data;
}

/**
 * Stores album data in cache with timestamp
 * @param {string} albumUri - Spotify album URI
 * @param {RYMAlbumData} data - Album data to cache
 * @returns {void}
 */
function setCachedData(albumUri, data) {
  albumCache.set(albumUri, {
    data,
    timestamp: Date.now()
  });
}

//#endregion

//#region Spotify Utilities

/**
 * Extracts Spotify album ID from Spotify URI
 * @param {string} uri - Spotify URI (e.g., "spotify:album:ABC123")
 * @returns {string|null} Album ID or null
 */
function extractSpotifyIdFromUri(uri) {
  if (!uri) {
    return null;
  }
  const parts = uri.split(':');
  return parts.length >= 3 ? parts[2] : null;
}

/**
 * Extracts Spotify album ID from RYM album page
 * @param {Document} doc - Parsed HTML document
 * @returns {string|null} Spotify album ID or null
 */
function extractSpotifyIdFromRYM(doc) {
  const spotifyLink = doc.querySelector(SELECTOR_SPOTIFY_LINK);
  if (!spotifyLink) {
    return null;
  }

  const href = spotifyLink.getAttribute('href');
  if (!href) {
    return null;
  }

  // Extract ID from URL: https://open.spotify.com/album/ABC123
  const match = href.match(/album\/([a-zA-Z0-9]+)/);
  return match ? match[1] : null;
}

//#endregion

//#region String Utilities

/**
 * Normalizes string for comparison (lowercase, removes special chars)
 * @param {string} str - Input string
 * @returns {string} Normalized string
 */
function normalizeString(str) {
  return str
    .toLowerCase()
    .replace(/[^\w\s]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

/**
 * Slugifies string for RYM URLs (lowercase, hyphens, remove special chars)
 * @param {string} str - Input string
 * @returns {string} Slugified string
 */
function slugify(str) {
  return str
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_]+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');
}

/**
 * Determines RYM release type from Spotify metadata
 * @param {AlbumInfo} albumInfo - Album information from Spotify
 * @returns {string} RYM release type: "album", "ep", "single", "comp", "mixtape"
 */
function determineRYMReleaseType(albumInfo) {
  const { album, albumType, totalTracks } = albumInfo;
  const albumLower = (album || '').toLowerCase();

  // Priority 1: Album name patterns (highest confidence)
  if (albumLower.includes('mixtape') || albumLower.includes('mix tape')) {
    return 'mixtape';
  }
  if (albumLower.match(/\bep\b|e\.p\./i)) {
    return 'ep';
  }
  if (albumLower.includes('compilation') || albumLower.includes('greatest hits')) {
    return 'comp';
  }

  // Priority 2: Spotify album_type + track count
  if (albumType === 'compilation') {
    return 'comp';
  }

  if (albumType === 'single') {
    if (totalTracks && totalTracks >= 4 && totalTracks <= 6) {
      return 'ep';
    }
    return 'single';
  }

  if (albumType === 'album') {
    if (totalTracks && totalTracks >= 4 && totalTracks <= 6) {
      return 'ep';
    }
    return 'album';
  }

  // Priority 3: Default fallback
  return 'album';
}

/**
 * Calculates similarity score between two strings (0.0 - 1.0)
 * @param {string} str1 - First string
 * @param {string} str2 - Second string
 * @returns {number} Similarity score
 */
function stringSimilarity(str1, str2) {
  const s1 = normalizeString(str1);
  const s2 = normalizeString(str2);

  if (s1 === s2) {
    return 1.0;
  }
  if (s1.includes(s2) || s2.includes(s1)) {
    return 0.8;
  }

  // Character overlap ratio
  const chars1 = new Set(s1.split(''));
  const chars2 = new Set(s2.split(''));
  const intersection = new Set([...chars1].filter(x => chars2.has(x)));
  const union = new Set([...chars1, ...chars2]);

  return intersection.size / union.size;
}

