//#region RYM Data Fetching

/**
 * Searches RYM for album and returns best match URL
 * @param {string} artist - Artist name
 * @param {string} album - Album name
 * @param {string|null} spotifyId - Spotify album ID for verification
 * @returns {Promise<string|null>} Album URL or null if not found
 */
async function searchRYM(artist, album, spotifyId = null) {
  try {
    const searchQuery = `${artist} ${album}`.trim();
    const searchUrl = `${RYM_BASE_URL}/search?searchterm=${encodeURIComponent(searchQuery)}&searchtype=l`;
    const proxiedUrl = CORS_PROXY + encodeURIComponent(searchUrl);

    console.log('RYM Extension: Searching for', searchQuery);

    const response = await fetch(proxiedUrl);
    if (!response.ok) {
      console.error('RYM Extension: Search request failed', response.status);
      return null;
    }

    const html = await response.text();

    // Detect Cloudflare challenge page
    if (html.includes('Just a moment') || html.includes('challenge-platform') || html.includes('cf_chl_opt')) {
      console.error('RYM Extension: Cloudflare blocked search request.');
      console.error('RYM Extension: Try switching CORS proxy or use a backend proxy server.');
      return null;
    }

    return parseSearchResults(html, artist, album, spotifyId);
  } catch (error) {
    console.error('RYM Extension: Search failed', error);
    return null;
  }
}

/**
 * Parses search results HTML and finds best album match
 * @param {string} html - Search results HTML
 * @param {string} targetArtist - Target artist name
 * @param {string} targetAlbum - Target album name
 * @param {string|null} spotifyId - Spotify album ID for verification
 * @returns {Promise<string|null>} Best match URL or null
 */
async function parseSearchResults(html, targetArtist, targetAlbum, spotifyId = null) {
  const parser = new DOMParser();
  const doc = parser.parseFromString(html, 'text/html');

  const results = doc.querySelectorAll(SELECTOR_SEARCH_RESULTS);

  if (!results || results.length === 0) {
    console.log('RYM Extension: No search results found');
    return null;
  }

  // If we have a Spotify ID, try to find exact match first
  if (spotifyId) {
    for (const result of results) {
      const titleLink = result.querySelector(SELECTOR_SEARCH_LINK);
      if (!titleLink) {
        continue;
      }

      const href = titleLink.getAttribute('href');
      if (!href) {
        continue;
      }

      const albumUrl = href.startsWith('http') ? href : `${RYM_BASE_URL}${href}`;

      // Fetch album page to check Spotify ID
      const verificationResult = await verifySpotifyMatch(albumUrl, spotifyId);
      if (verificationResult) {
        console.log('RYM Extension: Found perfect match via Spotify ID verification');
        return albumUrl;
      }
    }

    console.log('RYM Extension: No Spotify ID match found, falling back to fuzzy matching');
  }

  // Fall back to fuzzy matching
  let bestMatch = null;
  let bestScore = 0;

  for (const result of results) {
    const titleLink = result.querySelector(SELECTOR_SEARCH_LINK);
    if (!titleLink) {
      continue;
    }

    const fullText = titleLink.textContent || '';
    const href = titleLink.getAttribute('href');

    // RYM format: "Artist - Album"
    const parts = fullText.split(' - ');
    if (parts.length < 2) {
      continue;
    }

    const resultArtist = parts[0].trim();
    const resultAlbum = parts.slice(1).join(' - ').trim();

    const artistScore = stringSimilarity(targetArtist, resultArtist);
    const albumScore = stringSimilarity(targetAlbum, resultAlbum);
    const totalScore = (artistScore * ARTIST_WEIGHT) + (albumScore * ALBUM_WEIGHT);

    if (totalScore > bestScore) {
      bestScore = totalScore;
      bestMatch = href;
    }
  }

  if (bestScore < MIN_MATCH_SCORE) {
    console.log('RYM Extension: No good match found (best score:', bestScore, ')');
    return null;
  }

  const albumUrl = bestMatch.startsWith('http')
    ? bestMatch
    : `${RYM_BASE_URL}${bestMatch}`;

  console.log('RYM Extension: Found match with score', bestScore, '-', albumUrl);
  return albumUrl;
}

/**
 * Verifies if RYM album page matches Spotify album ID
 * @param {string} albumUrl - RYM album page URL
 * @param {string} spotifyId - Spotify album ID to verify
 * @returns {Promise<boolean>} True if IDs match
 */
async function verifySpotifyMatch(albumUrl, spotifyId) {
  try {
    const proxiedUrl = CORS_PROXY + encodeURIComponent(albumUrl);
    const response = await fetch(proxiedUrl);

    if (!response.ok) {
      return false;
    }

    const html = await response.text();
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');

    const rymSpotifyId = extractSpotifyIdFromRYM(doc);

    if (!rymSpotifyId) {
      return false;
    }

    return rymSpotifyId === spotifyId;
  } catch (error) {
    console.error('RYM Extension: Spotify verification failed', error);
    return false;
  }
}

/**
 * Fetches and parses RYM album page data
 * @param {string} albumUrl - RYM album page URL
 * @returns {Promise<RYMAlbumData|null>} Parsed album data or null
 */
async function fetchRYMAlbumData(albumUrl) {
  try {
    const proxiedUrl = CORS_PROXY + encodeURIComponent(albumUrl);

    console.log('RYM Extension: Fetching album data from', albumUrl);

    const response = await fetch(proxiedUrl);
    if (!response.ok) {
      console.error('RYM Extension: Album page request failed', response.status);
      return null;
    }

    const html = await response.text();

    // Detect Cloudflare challenge page
    if (html.includes('Just a moment') || html.includes('challenge-platform') || html.includes('cf_chl_opt')) {
      console.error('RYM Extension: Cloudflare blocked request. CORS proxy cannot bypass bot protection.');
      console.error('RYM Extension: This extension requires a backend proxy server to work reliably.');
      return null;
    }

    return parseRYMAlbumPage(html, albumUrl);
  } catch (error) {
    console.error('RYM Extension: Failed to fetch album page', error);
    return null;
  }
}

/**
 * Parses RYM album page HTML to extract metadata
 * @param {string} html - Album page HTML
 * @param {string} albumUrl - Album page URL
 * @returns {RYMAlbumData} Parsed album data
 */
function parseRYMAlbumPage(html, albumUrl) {
  const parser = new DOMParser();
  const doc = parser.parseFromString(html, 'text/html');

  const rating = extractRating(doc);
  const numRatings = extractNumRatings(doc);
  const { yearRank, overallRank } = extractRankings(doc);
  const genres = extractGenres(doc);
  const descriptors = extractDescriptors(doc);

  console.log('RYM Extension: Parsed data -', {
    rating,
    numRatings,
    yearRank,
    overallRank,
    genresCount: genres.length,
    descriptorsCount: descriptors.length
  });

  return {
    rating,
    numRatings,
    yearRank,
    overallRank,
    genres,
    descriptors,
    url: albumUrl
  };
}

/**
 * Extracts rating from album page
 * @param {Document} doc - Parsed HTML document
 * @returns {string|null} Rating value
 */
function extractRating(doc) {
  const ratingElement = doc.querySelector(SELECTOR_AVG_RATING);
  return ratingElement?.textContent?.trim() || null;
}

/**
 * Extracts number of ratings from album page
 * @param {Document} doc - Parsed HTML document
 * @returns {string|null} Number of ratings with commas
 */
function extractNumRatings(doc) {
  const numRatingsElement = doc.querySelector(SELECTOR_NUM_RATINGS);
  if (!numRatingsElement) {
    return null;
  }

  const text = numRatingsElement.textContent || '';
  const match = text.match(/[\d,]+/);
  return match ? match[0] : null;
}

/**
 * Extracts year and overall rankings from album page
 * @param {Document} doc - Parsed HTML document
 * @returns {{yearRank: YearRank|null, overallRank: string|null}} Rankings
 */
function extractRankings(doc) {
  let yearRank = null;
  let overallRank = null;

  // Find all info header rows
  const headers = doc.querySelectorAll(SELECTOR_INFO_HDR);

  for (const header of headers) {
    if (header.textContent?.includes('Ranked')) {
      const rankedCell = header.nextElementSibling;
      if (!rankedCell) {
        continue;
      }

      const text = rankedCell.textContent || '';

      // Extract year rank: "#98 for 2005"
      const yearMatch = text.match(/#([\d,]+)\s+for\s+(\d{4})/);
      if (yearMatch) {
        yearRank = { rank: yearMatch[1], year: yearMatch[2] };
      }

      // Extract overall rank: "#5,948 overall"
      const overallMatch = text.match(/#([\d,]+)\s+overall/);
      if (overallMatch) {
        overallRank = overallMatch[1];
      }

      break;
    }
  }

  return { yearRank, overallRank };
}

/**
 * Extracts primary genres from album page
 * @param {Document} doc - Parsed HTML document
 * @returns {string[]} Array of genre names
 */
function extractGenres(doc) {
  const genreElements = doc.querySelectorAll(SELECTOR_PRIMARY_GENRES);
  return Array.from(genreElements)
    .map(g => g.textContent.trim())
    .filter(g => g.length > 0)
    .slice(0, MAX_GENRES);
}

/**
 * Extracts descriptors from album page
 * @param {Document} doc - Parsed HTML document
 * @returns {string[]} Array of descriptor tags
 */
function extractDescriptors(doc) {
  const descriptorsElement = doc.querySelector(SELECTOR_PRIMARY_DESCRIPTORS);
  if (!descriptorsElement) {
    return [];
  }

  const text = descriptorsElement.textContent || '';
  return text
    .split(',')
    .map(d => d.trim())
    .filter(d => d.length > 0)
    .slice(0, MAX_DESCRIPTORS_PARSE);
}

