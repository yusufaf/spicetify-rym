 * @property {string} artist - Primary artist name
 * @property {string} album - Album name
 * @property {string} albumUri - Spotify album URI
 * @property {number|null} releaseDate - Release year
 * @property {string|null} albumType - Spotify album type: "album", "single", "compilation"
 * @property {number|null} totalTracks - Total track count
 */

/**
 * @typedef {Object} YearRank
 * @property {string} rank - Rank number (may include commas)
 * @property {string} year - Year of ranking
 */

/**
 * @typedef {Object} RYMAlbumData
 * @property {string|null} rating - Average rating (e.g., "3.64")
 * @property {string|null} numRatings - Number of ratings with commas
 * @property {YearRank|null} yearRank - Year-specific ranking
 * @property {string|null} overallRank - Overall ranking number
 * @property {string[]} genres - Array of genre names
 * @property {string[]} descriptors - Array of descriptor tags
 * @property {string} url - RYM album page URL
 */

/**
 * @typedef {Object} CachedData
 * @property {RYMAlbumData} data - Cached album data
 * @property {number} timestamp - Cache timestamp in milliseconds
 */

