//#region UI Components

/**
 * Creates main RYM container element
 * @returns {HTMLDivElement} Container element
 */
function createRYMContainer() {
  const container = document.createElement('div');
  container.id = CONTAINER_ID;
  container.className = 'rym-extension-container';
  return container;
}

/**
 * Creates rating display HTML
 * @param {RYMAlbumData} data - Album data
 * @returns {string} Rating section HTML
 */
function createRatingDisplay(data) {
  const yearRankHTML = data.yearRank
    ? `<div class="rym-rank">#${data.yearRank.rank} for ${data.yearRank.year}</div>`
    : '';

  const overallRankHTML = data.overallRank
    ? `<div class="rym-rank">#${data.overallRank} overall</div>`
    : '';

  return `
    <div class="rym-rating-section">
      <div class="rym-header">
        <span class="rym-title">RateYourMusic</span>
      </div>
      ${data.rating ? `
        <div class="rym-rating">
          <span class="rating-value">${data.rating}</span>
          <span class="rating-scale">/ 5.0</span>
        </div>
      ` : ''}
      ${data.numRatings ? `<div class="rym-ratings-count">${data.numRatings} ratings</div>` : ''}
      ${yearRankHTML}
      ${overallRankHTML}
    </div>
  `;
}

/**
 * Creates genres display HTML
 * @param {string[]} genres - Array of genre names
 * @returns {string} Genres section HTML or empty string
 */
function createGenresDisplay(genres) {
  if (!genres || genres.length === 0) {
    return '';
  }

  return `
    <div class="rym-genres-section">
      <h4>Genres</h4>
      <div class="rym-genres">
        ${genres.map(g => `<span class="genre-tag">${g}</span>`).join('')}
      </div>
    </div>
  `;
}

/**
 * Creates descriptors display HTML
 * @param {string[]} descriptors - Array of descriptor tags
 * @returns {string} Descriptors section HTML or empty string
 */
function createDescriptorsDisplay(descriptors) {
  if (!descriptors || descriptors.length === 0) {
    return '';
  }

  return `
    <div class="rym-descriptors-section">
      <h4>Descriptors</h4>
      <div class="rym-descriptors">
        ${descriptors.slice(0, MAX_DESCRIPTORS).map(d => `<span class="descriptor-tag">${d}</span>`).join('')}
      </div>
    </div>
  `;
}

/**
 * Injects RYM link into Spotify interface
 * @param {string} artist - Artist name
 * @param {string} album - Album name
 * @returns {void}
 */
function injectRYMSearchLink(artist, album) {
  // Try to find right sidebar content container
  let targetElement = document.querySelector(SELECTOR_RIGHT_SIDEBAR_CONTENT);

  // Fallback to alternative selector
  if (!targetElement) {
    targetElement = document.querySelector(SELECTOR_RIGHT_SIDEBAR_ALT);
  }

  if (!targetElement) {
    console.warn('RYM Extension: Could not find target element for UI injection');
    console.log('RYM Extension: Tried selectors:', SELECTOR_RIGHT_SIDEBAR_CONTENT, SELECTOR_RIGHT_SIDEBAR_ALT);
    return;
  }

  const existing = document.getElementById(CONTAINER_ID);
  if (existing) {
    existing.remove();
  }

  // Get full album info for release type detection
  const albumInfo = getCurrentAlbumInfo();
  const releaseType = albumInfo ? determineRYMReleaseType(albumInfo) : 'album';

  // Generate URLs
  const artistSlug = slugify(artist);
  const albumSlug = slugify(album);
  const albumUrl = `${RYM_BASE_URL}/release/${releaseType}/${artistSlug}/${albumSlug}/`;
  const searchUrl = `${RYM_BASE_URL}/search?searchterm=${encodeURIComponent(artist + ' ' + album)}`;

  const container = createRYMContainer();
  container.className = 'main-nowPlayingView-section main-nowPlayingView-rym';
  container.innerHTML = `
    <div class="main-nowPlayingView-sectionHeader">
      <h2 class="encore-text-body-medium-bold" data-encore-id="text">
        <div class="main-nowPlayingView-sectionHeaderText">RYM</div>
      </h2>
    </div>
    <div class="rym-content">
      <a href="${albumUrl}" target="_blank" rel="noopener noreferrer" class="rym-album-link">
        View on RateYourMusic
      </a>
      <div class="rym-fallback">
        <a href="${searchUrl}" target="_blank" rel="noopener noreferrer" class="rym-search-link">
          Wrong page? Search RYM
        </a>
      </div>
    </div>
  `;

  console.log('RYM Extension: Detected release type:', releaseType, 'for', album);
  console.log('RYM Extension: Injecting into', targetElement);
  targetElement.appendChild(container);
}

/**
 * Shows loading state in UI
 * @returns {void}
 */
function showLoadingState() {
  const container = createRYMContainer();
  container.innerHTML = '<div class="rym-loading">Loading RYM data...</div>';
  injectContainer(container);
}

/**
 * Shows "not found" state in UI
 * @returns {void}
 */
function showNotFoundState() {
  const container = createRYMContainer();
  container.innerHTML = '<div class="rym-not-found">Album not found on RYM</div>';
  injectContainer(container);
}

/**
 * Shows error state in UI
 * @returns {void}
 */
function showErrorState() {
  const container = createRYMContainer();
  container.innerHTML = '<div class="rym-error">Error loading RYM data</div>';
  injectContainer(container);
}

/**
 * Injects a container element into Spotify UI
 * @param {HTMLDivElement} container - Container to inject
 * @returns {void}
 */
function injectContainer(container) {
  let targetElement = document.querySelector(SELECTOR_SIDEBAR_CONTENT);

  if (!targetElement) {
    targetElement = document.querySelector(SELECTOR_RIGHT_SIDEBAR);
  }

  if (targetElement) {
    const existing = document.getElementById(CONTAINER_ID);
    if (existing) {
      existing.remove();
    }
    targetElement.appendChild(container);
  }
}

/**
 * Removes RYM UI from Spotify interface
 * @returns {void}
 */
function removeRYMUI() {
  const existing = document.getElementById(CONTAINER_ID);
  if (existing) {
    existing.remove();
  }
}

//#endregion

//#region Main Handler

/**
 * Handles album change events from Spotify
 * @returns {void}
 */
function handleAlbumChange() {
  const albumInfo = getCurrentAlbumInfo();

  if (!albumInfo || !albumInfo.artist || !albumInfo.album) {
    removeRYMUI();
    return;
  }

  if (albumInfo.albumUri === currentAlbumUri) {
    return;
  }
  currentAlbumUri = albumInfo.albumUri;

  console.log('RYM Extension: Album changed to', albumInfo.artist, '-', albumInfo.album);
  injectRYMSearchLink(albumInfo.artist, albumInfo.album);
}

